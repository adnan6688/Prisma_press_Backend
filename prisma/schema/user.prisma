model User {
    id String @id @default(ulid())
    name String
    email String @unique
    password String
    activeStatus ActiveStatus @default(ACTIVE)
    role UserRole @default(USER)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt



    profile  Profile?
    subscription SubsCription?
    
    comments Comment[]
    posts    Post[]

    @@map("users")
}
